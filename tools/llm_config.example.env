MIMO_API_KEY=your-api-key-here
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
TARGET_FRIENDS=11
SCAN_UNREAD=1

# 随机节奏（偏快，打破固定机器人特征）
POLL_INTERVAL_MIN=3
POLL_INTERVAL_MAX=6
REPLY_GAP_MIN=0.08
REPLY_GAP_MAX=0.35
SEND_DELAY_MIN=0.1
SEND_DELAY_MAX=0.28
LLM_GAP_MIN=0
LLM_GAP_MAX=0.2
ACTION_DELAY_MIN=0.1
ACTION_DELAY_MAX=0.25
